{
    "model_args": {
        "model_name": "openai/gpt-oss-20b",
        "tokenizer_name": "openai/gpt-oss-20b",
        "dtype": "bf16",
        "llm_operators": {
            "Norm": "JIT",
            "QKVProjection": "TPP",
            "Attention": "SLAB",
            "OutProjection": "TPP",
            "MLP": "TPP",
            "LMHead": "TPP"
        },
        "spec_config": null
    },
    "generation_args": {
        "batch_size": 1,
        "kv_cache_type": "SLAB_POOL",
        "think_end_token": "<|channel|>final<|message|>",
        "apply_chat_template": true,
        "fewshot_as_multiturn": false,
        "system_instruction": "After your reasoning, you must conclude with exactly: So the answer is <answer>."
    },
    "tasks": [
        {
            "task_name": "bbh_cot_fewshot",
            "num_fewshot": 3,
            "limit": null
        }
    ],
    "verbose": true,
    "output_dir": "./evaluation_results"
}
